@dataclass
class ValidationResult:
    """Resultado de validación"""
    is_valid: bool
    error_code: Optional[str]
    error_message: str
    tokens_saved: int
    severity: str  # CRITICAL, HIGH, MEDIUM, LOW, OK
 
 
class AgenteSmartValidator:
    """
    AGENTE 3: SMART-VALIDATOR
    
    Problema: Intentas analizar archivo corrupto → Error → 1,500 tokens wasted
    Solución: Validar ANTES (0 tokens) → Rechazar → Ahorrar 1,500 tokens
    Ahorro: 1,500 tokens (100% de lo que se habría gastado)
    
    EJEMPLO:
    >>> validator = AgenteSmartValidator()
    >>> result = validator.validate_before_analysis(archivo.py)
    >>> if not result.is_valid:
    ...     print(f"❌ {result.error_message} (Ahorrados: {result.tokens_saved} tokens)")
    """
    
    def __init__(self):
        self.validation_rules = self._setup_rules()
    
    def validate_before_analysis(self, content: str, file_type: str = "text") -> ValidationResult:
        """
        Valida contenido ANTES de enviarlo a análisis costoso.
        
        Args:
            content: Contenido a validar
            file_type: Tipo de archivo (python, json, markdown, text)
            
        Returns:
            ValidationResult con decisión
        """
        
        # Paso 1: Validaciones básicas (0 tokens)
        if not content or len(content) == 0:
            return ValidationResult(
                is_valid=False,
                error_code="EMPTY_CONTENT",
                error_message="Contenido vacío",
                tokens_saved=1500,  # Ahorrado costo de análisis
                severity="CRITICAL"
            )
        
        # Paso 2: Validación por tipo
        if file_type == "python":
            return self._validate_python(content)
        elif file_type == "json":
            return self._validate_json(content)
        elif file_type == "markdown":
            return self._validate_markdown(content)
        else:
            return self._validate_text(content)
    
    def _validate_python(self, content: str) -> ValidationResult:
        """Valida sintaxis Python básica"""
        
        # Intento compilar (local, sin tokens)
        try:
            compile(content, '<string>', 'exec')
            return ValidationResult(
                is_valid=True,
                error_code=None,
                error_message="✓ Código Python válido",
                tokens_saved=0,
                severity="OK"
            )
        except SyntaxError as e:
            return ValidationResult(
                is_valid=False,
                error_code="SYNTAX_ERROR",
                error_message=f"Error de sintaxis en línea {e.lineno}: {e.msg}",
                tokens_saved=1500,
                severity="CRITICAL"
            )
    
    def _validate_json(self, content: str) -> ValidationResult:
        """Valida JSON"""
        try:
            json.loads(content)
            return ValidationResult(
                is_valid=True,
                error_code=None,
                error_message="✓ JSON válido",
                tokens_saved=0,
                severity="OK"
            )
        except json.JSONDecodeError as e:
            return ValidationResult(
                is_valid=False,
                error_code="JSON_INVALID",
                error_message=f"JSON inválido: {e.msg} en línea {e.lineno}",
                tokens_saved=1500,
                severity="CRITICAL"
            )
    
    def _validate_markdown(self, content: str) -> ValidationResult:
        """Valida Markdown básico"""
        
        # Verificaciones simples
        issues = []
        
        if content.count('[') != content.count(']'):
            issues.append("Corchetes desbalanceados")
        
        if content.count('(') != content.count(')'):
            issues.append("Paréntesis desbalanceados")
        
        if issues:
            return ValidationResult(
                is_valid=False,
                error_code="MARKDOWN_INVALID",
                error_message=f"Problemas en Markdown: {', '.join(issues)}",
                tokens_saved=500,
                severity="HIGH"
            )
        
        return ValidationResult(
            is_valid=True,
            error_code=None,
            error_message="✓ Markdown válido",
            tokens_saved=0,
            severity="OK"
        )
    
    def _validate_text(self, content: str) -> ValidationResult:
        """Validación genérica de texto"""
        
        # Verificaciones básicas
        if len(content) < 10:
            return ValidationResult(
                is_valid=False,
                error_code="TOO_SHORT",
                error_message="Contenido demasiado corto (<10 caracteres)",
                tokens_saved=200,
                severity="MEDIUM"
            )
        
        return ValidationResult(
            is_valid=True,
            error_code=None,
            error_message="✓ Contenido válido",
            tokens_saved=0,
            severity="OK"
        )
    
    def _setup_rules(self) -> Dict:
        """Configura reglas de validación"""
        return {
            "min_length": 10,
            "max_length": 1000000,
            "allowed_types": ["python", "json", "markdown", "text"]
        }
 
 
