class AgenteContextualRouter:
    """
    AGENTE 5: CONTEXTUAL-ROUTER
    
    Problema: Ejecutas TODO el pipeline (5 agentes) aunque solo necesites 1
    Solución: Detectar necesidad → Ejecutar SOLO agentes relevantes
    Ahorro: 60-80% de tokens (no gastas en agentes innecesarios)
    
    EJEMPLO:
    >>> router = AgenteContextualRouter()
    >>> route = router.decide_route("Pregunta simple sobre Python")
    >>> print(f"Ejecutar solo: {route.agents_to_run}")
    # Output: ['Router']  (no necesita Analyzer, Validator, etc)
    """
    
    def __init__(self):
        self.routes = self._define_routes()
    
    def decide_route(self, query: str) -> Dict[str, Any]:
        """
        Decide qué agentes ejecutar basado en la query.
        
        Returns:
            {
                "route_type": "simple|medium|complex",
                "agents_to_run": [list de agentes],
                "estimated_tokens": int,
                "reasoning": str
            }
        """
        
        # Analizar complejidad de la query
        complexity = self._analyze_complexity(query)
        
        if complexity == "simple":
            return {
                "route_type": "simple",
                "agents_to_run": ["Router"],
                "estimated_tokens": 150,
                "reasoning": "Pregunta simple, Router es suficiente"
            }
        elif complexity == "medium":
            return {
                "route_type": "medium",
                "agents_to_run": ["Router", "Analyzer"],
                "estimated_tokens": 600,
                "reasoning": "Necesita análisis, pero no validación completa"
            }
        else:
            return {
                "route_type": "complex",
                "agents_to_run": ["Router", "Analyzer", "Validator", "Generator"],
                "estimated_tokens": 1500,
                "reasoning": "Tarea compleja, ejecuta pipeline completo"
            }
    
    def _analyze_complexity(self, query: str) -> str:
        """Analiza complejidad de la query"""
        
        simple_words = ["qué", "cuál", "dónde", "cuándo", "quién"]
        complex_words = ["analiza", "evalúa", "compara", "diseña", "optimiza"]
        
        query_lower = query.lower()
        
        if any(word in query_lower for word in complex_words):
            return "complex"
        elif any(word in query_lower for word in simple_words):
            return "simple"
        else:
            return "medium"
    
    def _define_routes(self) -> Dict:
        return {
            "simple": {
                "agents": ["Router"],
                "cost": 150
            },
            "medium": {
                "agents": ["Router", "Analyzer"],
                "cost": 600
            },
            "complex": {
                "agents": ["Router", "Analyzer", "Validator", "Generator"],
                "cost": 1500
            }
        }
 
 
