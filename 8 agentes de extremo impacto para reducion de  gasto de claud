@dataclass
class CompositionTemplate:
    """Plantilla para composición de resultados"""
    name: str
    format_type: str  # json, markdown, text, structured
    fields: List[str]
    merge_strategy: str  # concat, merge_json, summarize
 
 
@dataclass
class ComposedResult:
    """Resultado compuesto de múltiples fuentes"""
    composition_type: str
    final_result: str
    source_results: Dict[str, str]
    tokens_used: int
    tokens_saved: int
    quality_score: float  # 0-100
 
 
class AgenteResultComposer:
    """
    AGENTE 8: RESULT-COMPOSER
    
    Problema:
    Ejecutas 3 agentes → Obtienes 3 resultados en diferentes formatos
    Combinarlos manualmente es ineficiente y propenso a errores
    
    Solución:
    Composer automáticamente:
    - Detecta formato de cada resultado
    - Convierte a formato común
    - Fusiona información sin duplicación
    - Genera salida final coherente
    
    EJEMPLO:
    >>> composer = AgenteResultComposer()
    >>> result = composer.compose(
    ...     results={
    ...         "validator": "✓ Input válido",
    ...         "analyzer": "Encontró 5 issues",
    ...         "generator": "Propone 3 soluciones"
    ...     },
    ...     target_format="markdown"
    ... )
    >>> print(result.final_result)
    """
    
    def __init__(self):
        self.templates = self._load_templates()
        self.composition_history = []
    
    def compose(
        self,
        results: Dict[str, str],
        target_format: str = "markdown",
        merge_strategy: str = "smart"
    ) -> ComposedResult:
        """
        Compone múltiples resultados en uno coherente.
        
        Args:
            results: Dict de {agent_name: result_string}
            target_format: Formato final (json, markdown, text)
            merge_strategy: Estrategia de fusión
        """
        
        start_time = datetime.now()
        
        # Paso 1: Normalizar todos los resultados
        normalized = {}
        for agent_name, result in results.items():
            normalized[agent_name] = self._normalize_result(result)
        
        # Paso 2: Detectar duplicación
        deduplicated = self._remove_duplicates(normalized)
        
        # Paso 3: Determinar orden de presentación (heurística)
        ordered_results = self._order_results(deduplicated)
        
        # Paso 4: Componer según formato
        if target_format == "markdown":
            final = self._compose_markdown(ordered_results)
        elif target_format == "json":
            final = self._compose_json(ordered_results)
        elif target_format == "text":
            final = self._compose_text(ordered_results)
        else:
            final = self._compose_structured(ordered_results)
        
        # Paso 5: Calcular métricas
        tokens_used = sum(len(r) // 4 for r in normalized.values())
        tokens_saved = self._calculate_savings(results, final)
        quality = self._estimate_quality(final, len(results))
        
        elapsed = (datetime.now() - start_time).total_seconds() * 1000
        
        composed = ComposedResult(
            composition_type=target_format,
            final_result=final,
            source_results=results,
            tokens_used=tokens_used,
            tokens_saved=tokens_saved,
            quality_score=quality
        )
        
        self.composition_history.append(composed)
        return composed
    
    def _normalize_result(self, result: str) -> str:
        """Normaliza formato de resultado"""
        # Remover espacios excesivos
        result = " ".join(result.split())
        # Normalizar puntuación
        result = result.replace(" .", ".")
        return result
    
    def _remove_duplicates(self, results: Dict[str, str]) -> Dict[str, str]:
        """Elimina información duplicada entre resultados"""
        if len(results) < 2:
            return results
        
        # Estrategia simple: mantener primera ocurrencia
        seen_sentences = set()
        deduplicated = {}
        
        for agent, result in results.items():
            sentences = result.split(".")
            unique_sentences = []
            
            for sentence in sentences:
                sentence = sentence.strip()
                if sentence and sentence not in seen_sentences:
                    unique_sentences.append(sentence)
                    seen_sentences.add(sentence)
            
            deduplicated[agent] = ". ".join(unique_sentences)
        
        return deduplicated
    
    def _order_results(self, results: Dict[str, str]) -> Dict[str, str]:
        """Ordena resultados de forma lógica"""
        # Orden lógico: Validator → Analyzer → Generator → Custom
        priority_order = ["validator", "analyzer", "generator", "compressor"]
        
        ordered = {}
        for agent in priority_order:
            if agent in results:
                ordered[agent] = results[agent]
        
        # Añadir resto
        for agent, result in results.items():
            if agent not in ordered:
                ordered[agent] = result
        
        return ordered
    
    def _compose_markdown(self, results: Dict[str, str]) -> str:
        """Compone resultado en formato Markdown"""
        lines = ["# Análisis Completo\n"]
        
        for agent_name, result in results.items():
            lines.append(f"## {agent_name.title()}\n")
            lines.append(f"{result}\n")
        
        return "\n".join(lines)
    
    def _compose_json(self, results: Dict[str, str]) -> str:
        """Compone resultado en formato JSON"""
        import json
        return json.dumps(results, indent=2, ensure_ascii=False)
    
    def _compose_text(self, results: Dict[str, str]) -> str:
        """Compone resultado en texto plano"""
        lines = []
        for agent_name, result in results.items():
            lines.append(f"{agent_name.upper()}: {result}")
        return "\n".join(lines)
    
    def _compose_structured(self, results: Dict[str, str]) -> str:
        """Compone resultado estructurado"""
        lines = ["RESULTADO FINAL"]
        lines.append("=" * 50)
        for agent_name, result in results.items():
            lines.append(f"\n[{agent_name}]")
            lines.append(f"→ {result}")
        return "\n".join(lines)
    
    def _calculate_savings(self, original: Dict, composed: str) -> int:
        """Calcula tokens ahorrados por deduplicación"""
        original_size = sum(len(v) for v in original.values())
        composed_size = len(composed)
        saved = max(0, (original_size - composed_size) // 4)
        return saved
    
    def _estimate_quality(self, result: str, num_sources: int) -> float:
        """Estima calidad de composición"""
        # Factores:
        # - Longitud del resultado
        # - Número de fuentes
        # - Coherencia (simple heurística)
        
        length_score = min(100, len(result) / 100)
        source_score = (num_sources / 5) * 100  # Ideal: 5 fuentes
        
        return (length_score + source_score) / 2
    
    def _load_templates(self) -> Dict[str, CompositionTemplate]:
        return {
            "simple": CompositionTemplate(
                name="Simple",
                format_type="text",
                fields=["summary", "findings"],
                merge_strategy="concat"
            ),
            "detailed": CompositionTemplate(
                name="Detailed",
                format_type="markdown",
                fields=["introduction", "analysis", "findings", "recommendations"],
                merge_strategy="summarize"
            )
        }
 
 
