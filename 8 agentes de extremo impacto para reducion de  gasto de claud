def example_extreme_impact_workflow():
    """
    Demuestra cómo los 5 agentes trabajan juntos para ahorrar tokens
    """
    
    print("\n" + "="*70)
    print("🔥 WORKFLOW: 5 AGENTES DE IMPACTO EXTREMO")
    print("="*70)
    
    # Escenario: Usuario quiere analizar documento largo
    documento = """
    Este es un documento muy largo sobre seguridad en la nube.
    
    # Introducción
    La seguridad en la nube es crítica...
    
    # Problemas
    Hay varios problemas importantes...
    """ * 50  # Simular documento de 50 repeticiones
    
    print(f"\n📄 ENTRADA: Documento de {len(documento)} caracteres (~{len(documento)//4} tokens sin optimización)")
    
    # AGENTE 1: VALIDATOR
    print("\n[1/5] AGENTE VALIDATOR (Validación previa)")
    validator = AgenteSmartValidator()
    val_result = validator.validate_before_analysis(documento, "text")
    print(f"✓ Validación: {val_result.error_message}")
    print(f"✓ Tokens ahorrados si fuera inválido: {val_result.tokens_saved}")
    
    # AGENTE 2: COMPRESSOR
    print("\n[2/5] AGENTE COMPRESSOR (Compresión)")
    compressor = AgenteCompressor()
    comp_result = compressor.compress(documento, CompressionLevel.MEDIUM)
    print(f"✓ Compresión: {comp_result.compression_ratio*100:.1f}%")
    print(f"✓ Tokens ahorrados: {comp_result.tokens_saved}")
    
    # AGENTE 3: DEDUPLICATOR
    print("\n[3/5] AGENTE DEDUPLICATOR (Deduplicación)")
    dedup = AgenteDeduplicator()
    dedup_result = dedup.check_duplicate("Analizar seguridad en la nube", "analysis")
    print(f"✓ ¿Es duplicado?: {dedup_result.is_duplicate}")
    print(f"✓ Sugerencia: {dedup_result.suggestion}")
    
    # AGENTE 4: PRE-PROCESSOR
    print("\n[4/5] AGENTE PRE-PROCESSOR (Preparación)")
    preprocessor = AgentePreProcessor()
    preproc_result = preprocessor.preprocess(documento, "text")
    print(f"✓ Mejoras aplicadas: {', '.join(preproc_result.improvements)}")
    print(f"✓ Boost de calidad estimado: {preproc_result.estimated_quality_boost}%")
    
    # AGENTE 5: CONTEXTUAL-ROUTER
    print("\n[5/5] AGENTE CONTEXTUAL-ROUTER (Enrutamiento)")
    router = AgenteContextualRouter()
    route = router.decide_route("Analiza este documento de seguridad en la nube")
    print(f"✓ Ruta decidida: {route['route_type'].upper()}")
    print(f"✓ Agentes a ejecutar: {', '.join(route['agents_to_run'])}")
    print(f"✓ Tokens estimados: {route['estimated_tokens']}")
    
    # RESUMEN
    print("\n" + "="*70)
    print("📊 AHORRO TOTAL")
    print("="*70)
    tokens_sin_optimizacion = len(documento) // 4 + 1500  # análisis
    tokens_con_optimizacion = 1500 + comp_result.tokens_saved  # análisis + compresión
    ahorro_total = tokens_sin_optimizacion - tokens_con_optimizacion
    
