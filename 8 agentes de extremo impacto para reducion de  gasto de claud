class CompressionLevel(Enum):
    """Niveles de compresión"""
    LIGHT = 0.9  # Mantiene 90% info, reduce 10%
    MEDIUM = 0.7  # Mantiene 70% info, reduce 30%
    AGGRESSIVE = 0.5  # Mantiene 50% info, reduce 50%
 
 
@dataclass
class CompressionMetrics:
    """Métricas de compresión"""
    original_size: int
    compressed_size: int
    compression_ratio: float
    tokens_saved: int
    info_retained: float  # 0-1, qué porcentaje de info importante se mantiene
    compression_time_ms: int
 
 
class AgenteCompressor:
    """
    AGENTE 1: COMPRESSOR
    
    Problema: Un documento de 100 líneas cuesta 3,000 tokens analizarlo.
    Solución: Comprimir a 10 puntos clave (300 tokens) + analizar esos (800 tokens) = 1,100 tokens
    Ahorro: 1,900 tokens (63%)
    
    EJEMPLO:
    >>> compressor = AgenteCompressor()
    >>> original = "Este es un documento largo sobre ciberseguridad..."
    >>> compressed = compressor.compress(original, level=CompressionLevel.MEDIUM)
    >>> print(f"Ahorro: {compressed.tokens_saved} tokens")
    """
    
    def __init__(self):
        self.compression_history = {}
    
    def compress(
        self,
        content: str,
        level: CompressionLevel = CompressionLevel.MEDIUM,
        preserve_keywords: List[str] = None
    ) -> CompressionMetrics:
        """
        Comprime contenido manteniendo información clave.
        
        Args:
            content: Texto a comprimir
            level: Nivel de compresión (LIGHT, MEDIUM, AGGRESSIVE)
            preserve_keywords: Palabras clave que SIEMPRE mantener
            
        Returns:
            Métricas de compresión
        """
        
        start_time = datetime.now()
        original_size = len(content)
        
        # Paso 1: Extraer puntos clave
        key_points = self._extract_key_points(content, level)
        
        # Paso 2: Comprimir manteniendo estructura
        compressed = self._compress_content(content, key_points, level, preserve_keywords)
        
        compressed_size = len(compressed)
        compression_ratio = 1 - (compressed_size / original_size) if original_size > 0 else 0
        
        # Paso 3: Estimar tokens ahorrados
        # Regla: ~1 token = 4 caracteres
        tokens_original = original_size // 4
        tokens_compressed = compressed_size // 4
        tokens_saved = tokens_original - tokens_compressed
        
        # Paso 4: Calcular información retenida
        info_retained = len(key_points) / max(1, len(content.split()))
        
        elapsed_ms = int((datetime.now() - start_time).total_seconds() * 1000)
        
        metrics = CompressionMetrics(
            original_size=original_size,
            compressed_size=compressed_size,
            compression_ratio=compression_ratio,
            tokens_saved=tokens_saved,
            info_retained=min(1.0, info_retained),
            compression_time_ms=elapsed_ms
        )
        
        return metrics
    
    def _extract_key_points(self, content: str, level: CompressionLevel) -> List[str]:
        """Extrae puntos clave del contenido"""
        
        # Estrategia simple: oraciones con palabras clave
        keywords = [
            "importante", "crítico", "debe", "requiere", "error",
            "seguridad", "protección", "vulnerabilidad", "ataque",
            "solución", "recomendación", "conclusión"
        ]
        
        sentences = content.split('.')
        key_points = []
        
        target_count = max(1, int(len(sentences) * (1 - level.value)))
        
        for sentence in sentences:
            if len(key_points) >= target_count:
                break
            
            if any(kw in sentence.lower() for kw in keywords):
                key_points.append(sentence.strip())
        
        return key_points
    
    def _compress_content(
        self,
        content: str,
        key_points: List[str],
        level: CompressionLevel,
        preserve_keywords: List[str] = None
    ) -> str:
        """Comprime el contenido manteniendo puntos clave"""
        
        preserve_keywords = preserve_keywords or []
        
        # Crear versión comprimida basada en key_points
        compressed_lines = []
        for point in key_points:
            if point:
                compressed_lines.append(f"• {point.strip()}")
        
        # Añadir palabras clave que se deben preservar
        for keyword in preserve_keywords:
            if keyword not in "\n".join(compressed_lines):
                compressed_lines.append(f"• Mencionar: {keyword}")
        
        return "\n".join(compressed_lines)
 
 
