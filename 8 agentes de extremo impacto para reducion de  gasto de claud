@dataclass
class DeduplicationResult:
    """Resultado de deduplicación"""
    is_duplicate: bool
    similarity_score: float  # 0-1
    cached_result_id: Optional[str]
    tokens_saved: int
    suggestion: str
 
 
class AgenteDeduplicator:
    """
    AGENTE 2: DEDUPLICATOR
    
    Problema: Pides el mismo análisis 5 veces = 5 × 2,000 = 10,000 tokens
    Solución: Detectar duplicado, devolver cached = 10 tokens
    Ahorro: 9,990 tokens (99.9%)
    
    EJEMPLO:
    >>> dedup = AgenteDeduplicator()
    >>> result = dedup.check_duplicate("Analizar código Python")
    >>> if result.is_duplicate:
    ...     print(f"¡Ya lo hicimos! Tokens ahorrados: {result.tokens_saved}")
    """
    
    def __init__(self, similarity_threshold: float = 0.85):
        self.cache = {}  # {hash: (content, result, timestamp)}
        self.similarity_threshold = similarity_threshold
        self.total_tokens_saved = 0
    
    def check_duplicate(
        self,
        query: str,
        operation_type: str = "analysis"
    ) -> DeduplicationResult:
        """
        Verifica si una operación ya se hizo.
        
        Args:
            query: Consulta o descripción de lo que quieres
            operation_type: Tipo de operación (analysis, generation, validation, etc)
            
        Returns:
            DeduplicationResult con decisión
        """
        
        # Paso 1: Crear hash de la consulta
        query_hash = self._create_hash(query, operation_type)
        
        # Paso 2: Verificar si existe en caché
        if query_hash in self.cache:
            cached_time = self.cache[query_hash]['timestamp']
            age_hours = (datetime.now() - cached_time).total_seconds() / 3600
            
            # Si está fresco (< 24 horas), es un hit
            if age_hours < 24:
                tokens_saved = 2000  # Costo típico de análisis
                self.total_tokens_saved += tokens_saved
                
                return DeduplicationResult(
                    is_duplicate=True,
                    similarity_score=1.0,
                    cached_result_id=query_hash,
                    tokens_saved=tokens_saved,
                    suggestion=f"Resultado en caché (guardado hace {int(age_hours)}h)"
                )
            else:
                # Caché expirado, limpiar
                del self.cache[query_hash]
        
        # Paso 3: Buscar similares (similarity matching)
        for cached_hash, (cached_query, cached_result, timestamp) in self.cache.items():
            similarity = self._calculate_similarity(query, cached_query)
            
            if similarity >= self.similarity_threshold:
                age_hours = (datetime.now() - timestamp).total_seconds() / 3600
                if age_hours < 24:
                    tokens_saved = int(2000 * similarity)  # Ahorro proporcional
                    self.total_tokens_saved += tokens_saved
                    
                    return DeduplicationResult(
                        is_duplicate=True,
                        similarity_score=similarity,
                        cached_result_id=cached_hash,
                        tokens_saved=tokens_saved,
                        suggestion=f"Muy similar a análisis anterior ({similarity*100:.0f}% match)"
                    )
        
        # No es duplicado
        return DeduplicationResult(
            is_duplicate=False,
            similarity_score=0.0,
            cached_result_id=None,
            tokens_saved=0,
            suggestion="Nueva consulta, proceder con análisis completo"
        )
    
    def store_result(self, query: str, operation_type: str, result: Any):
        """Almacena resultado para futuros duplicados"""
        query_hash = self._create_hash(query, operation_type)
        self.cache[query_hash] = (query, result, datetime.now())
    
    def _create_hash(self, query: str, operation_type: str) -> str:
        """Crea hash único para query"""
        combined = f"{operation_type}:{query}"
        return hashlib.md5(combined.encode()).hexdigest()[:16]
    
    def _calculate_similarity(self, s1: str, s2: str) -> float:
        """Calcula similitud de coseno entre dos strings"""
        set1 = set(s1.lower().split())
        set2 = set(s2.lower().split())
        
        if not set1 or not set2:
            return 0.0
        
        intersection = len(set1 & set2)
        union = len(set1 | set2)
        
        return intersection / union if union > 0 else 0.0
 
 
