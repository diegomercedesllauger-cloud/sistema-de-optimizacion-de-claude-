@dataclass
class CostEstimate:
    """Estimación de costo para una operación"""
    operation_type: str
    base_cost: int
    input_size_factor: float
    complexity_factor: float
    estimated_total: int
    confidence_level: float  # 0-1, qué tan seguro está
    breakdown: Dict[str, int]  # Desglose por componente
    recommendation: str
 
 
class AgenteCostEstimator:
    """
    AGENTE 7: COST-ESTIMATOR
    
    Problema:
    No sabes cuánto costará una operación ANTES de hacerla.
    Puedes terminar gastando 5,000 tokens cuando esperabas 1,000.
    
    Solución:
    Estimar costo ANTES (50 tokens) → Decidir si proceder o no
    
    EJEMPLO:
    >>> estimator = AgenteCostEstimator()
    >>> estimate = estimator.estimate("analyze", document_size=50000, complexity="high")
    >>> print(f"Costo estimado: {estimate.estimated_total} tokens")
    >>> if estimate.estimated_total > 2000:
    ...     print(f"Recomendación: {estimate.recommendation}")
    # Output: Costo estimado: 2500 tokens
    #         Recomendación: Considera comprimidor ANTES de analizar
    """
    
    def __init__(self):
        self.operation_costs = self._load_operation_costs()
        self.historical_data = {}
    
    def estimate(
        self,
        operation_type: str,
        input_size: int = 0,
        complexity: str = "medium",
        additional_factors: Dict = None
    ) -> CostEstimate:
        """
        Estima el costo de una operación.
        
        Args:
            operation_type: Tipo de operación (analyze, generate, validate, etc)
            input_size: Tamaño de entrada en caracteres
            complexity: Complejidad (simple, medium, complex)
            additional_factors: Factores adicionales
        """
        
        additional_factors = additional_factors or {}
        
        # Paso 1: Obtener costo base
        base_cost = self.operation_costs.get(operation_type, 300)
        
        # Paso 2: Factor de tamaño de entrada
        # Regla: ~1 token = 4 caracteres
        tokens_from_input = input_size // 4
        input_factor = 1 + (tokens_from_input / 1000)  # Multiplicador
        
        # Paso 3: Factor de complejidad
        complexity_factors = {
            "simple": 0.5,
            "medium": 1.0,
            "complex": 2.0,
            "extreme": 3.0
        }
        complexity_factor = complexity_factors.get(complexity, 1.0)
        
        # Paso 4: Calcular estimación
        estimated = int(base_cost * input_factor * complexity_factor)
        
        # Paso 5: Ajustar por factores adicionales
        for factor_name, factor_value in additional_factors.items():
            estimated = int(estimated * factor_value)
        
        # Paso 6: Determinar nivel de confianza
        confidence = 0.85  # Generalmente 85% de confianza
        if input_size == 0:
            confidence = 0.6  # Menos confianza sin tamaño
        
        # Paso 7: Crear recomendación
        recommendation = self._generate_recommendation(estimated, operation_type)
        
        # Paso 8: Desglose
        breakdown = {
            "base_cost": base_cost,
            "input_cost": int(tokens_from_input),
            "complexity_multiplier": int(base_cost * complexity_factor),
            "total": estimated
        }
        
        return CostEstimate(
            operation_type=operation_type,
            base_cost=base_cost,
            input_size_factor=input_factor,
            complexity_factor=complexity_factor,
            estimated_total=estimated,
            confidence_level=confidence,
            breakdown=breakdown,
            recommendation=recommendation
        )
    
    def _generate_recommendation(self, cost: int, operation_type: str) -> str:
        """Genera recomendación basada en costo"""
        
        if cost > 3000:
            return f"⚠️ COSTO ALTO: Considera usar COMPRESSOR antes de {operation_type}"
        elif cost > 1500:
            return f"💡 Costo medio. Verifica si hay duplicados en caché"
        else:
            return "✓ Costo bajo. Proceder con confianza"
    
    def _load_operation_costs(self) -> Dict[str, int]:
        """Carga costos típicos de operaciones"""
        return {
            "analyze": 600,
            "generate": 800,
            "validate": 200,
            "compress": 150,
            "deduplicate": 100,
            "preprocess": 120,
            "route": 100,
        }
    
    def record_actual_cost(self, operation_type: str, actual_cost: int):
        """Registra costo real para mejorar futuras estimaciones"""
        if operation_type not in self.historical_data:
            self.historical_data[operation_type] = []
        self.historical_data[operation_type].append(actual_cost)
 
 
