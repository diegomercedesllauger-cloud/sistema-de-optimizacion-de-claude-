@dataclass
class CacheEntry:
    """Entrada en caché"""
    key: str
    value: Any
    tokens_saved: int
    created_at: datetime
    last_accessed: datetime
    access_count: int = 0
    ttl_hours: int = 24
 
 
class AgenteClassInteligente:
    """
    Agente 2: Caché Inteligente
    
    Almacena resultados + prompts + análisis.
    Reutiliza automáticamente si es similar.
    Ahorra 60-80% tokens en operaciones repetidas.
    
    EJEMPLO:
    >> cache = AgenteClassInteligente()
    >> cache.store("documento_python", resultado, tokens_saved=2100)
    >> similar = cache.find_similar("código python similar")  # Devuelve hit si existe
    """
    
    def __init__(self, max_entries: int = 1000):
        self.cache: Dict[str, CacheEntry] = {}
        self.max_entries = max_entries
        self.hits = 0
        self.misses = 0
    
    def generate_key(self, data: str, operation_type: str) -> str:
        """Genera clave única para entrada"""
        content_hash = hashlib.md5(data.encode()).hexdigest()[:8]
        return f"{operation_type}:{content_hash}"
    
    def store(self, key: str, value: Any, tokens_saved: int = 0):
        """Almacena resultado en caché"""
        if len(self.cache) >= self.max_entries:
            self._evict_lru()
        
        self.cache[key] = CacheEntry(
            key=key,
            value=value,
            tokens_saved=tokens_saved,
            created_at=datetime.now(),
            last_accessed=datetime.now(),
        )
    
    def retrieve(self, key: str) -> Optional[Any]:
        """Recupera resultado del caché"""
        if key in self.cache:
            entry = self.cache[key]
            
            # Verificar TTL
            if datetime.now() - entry.created_at > timedelta(hours=entry.ttl_hours):
                del self.cache[key]
                self.misses += 1
                return None
            
            # Actualizar acceso
            entry.last_accessed = datetime.now()
            entry.access_count += 1
            self.hits += 1
            
            return entry.value
        
        self.misses += 1
        return None
    
    def find_similar(self, query: str, threshold: float = 0.8) -> Optional[Tuple[str, Any]]:
        """Busca entrada similar en caché"""
        for key, entry in self.cache.items():
            similarity = self._calculate_similarity(query, key)
            if similarity >= threshold:
                self.hits += 1
                entry.access_count += 1
                return (key, entry.value)
        
        self.misses += 1
        return None
    
    def _calculate_similarity(self, s1: str, s2: str) -> float:
        """Calcula similitud entre strings"""
        set1 = set(s1.lower().split())
        set2 = set(s2.lower().split())
        
        if not set1 or not set2:
            return 0.0
        
        intersection = len(set1 & set2)
        union = len(set1 | set2)
        
        return intersection / union if union > 0 else 0.0
    
    def _evict_lru(self):
        """Elimina entrada menos usada recientemente"""
        lru_key = min(
            self.cache.keys(),
            key=lambda k: self.cache[k].last_accessed
        )
        del self.cache[lru_key]
    
    def get_stats(self) -> Dict:
        """Retorna estadísticas del caché"""
        total_saved = sum(e.tokens_saved for e in self.cache.values())
        total_access = self.hits + self.misses
        hit_rate = (self.hits / total_access * 100) if total_access > 0 else 0
        
        return {
            "total_entries": len(self.cache),
            "tokens_saved": total_saved,
            "hit_rate": hit_rate,
            "total_hits": self.hits,
            "total_misses": self.misses,
        }
 
 
