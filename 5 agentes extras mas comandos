@dataclass
class FallbackStrategy:
    """Estrategia de fallback"""
    method: str
    cost_tokens: int
    description: str
    success_rate: float
 
 
class AgenteClassFallback:
    """
    Agente 4: Fallback Inteligente
    
    Si Agente 1 falla, intenta método alternativo.
    Sin reintentos costosos innecesarios.
    
    EJEMPLO:
    >> fallback = AgenteClassFallback()
    >> result = fallback.try_with_fallback(
    ...     primary=lambda: agente_costoso(),
    ...     fallbacks=[
    ...         (lambda: agente_barato(), 200),
    ...         (lambda: usar_cache(), 10),
    ...     ]
    ... )
    """
    
    def __init__(self):
        self.fallback_strategies: Dict[str, List[FallbackStrategy]] = {}
        self.successful_fallbacks = 0
    
    def register_strategy(
        self,
        operation: str,
        method: str,
        cost: int,
        description: str,
        success_rate: float = 0.8
    ):
        """Registra estrategia de fallback para operación"""
        if operation not in self.fallback_strategies:
            self.fallback_strategies[operation] = []
        
        self.fallback_strategies[operation].append(
            FallbackStrategy(
                method=method,
                cost_tokens=cost,
                description=description,
                success_rate=success_rate,
            )
        )
    
    def try_with_fallback(
        self,
        operation: str,
        primary_method: callable,
        max_fallbacks: int = 3
    ) -> Tuple[bool, Any, str]:
        """
        Intenta operación con fallbacks automáticos
        
        Returns: (success, result, method_used)
        """
        
        # 1. Intentar método primario
        try:
            result = primary_method()
            return (True, result, "primary")
        except Exception as e:
            print(f"Primary failed: {e}")
        
        # 2. Intentar fallbacks en orden
        if operation in self.fallback_strategies:
            fallbacks = sorted(
                self.fallback_strategies[operation],
                key=lambda x: x.cost_tokens
            )
            
            for i, strategy in enumerate(fallbacks[:max_fallbacks]):
                try:
                    result = self._execute_fallback(strategy)
                    self.successful_fallbacks += 1
                    return (True, result, strategy.method)
                except Exception as e:
                    print(f"Fallback {i+1} ({strategy.method}) failed: {e}")
                    continue
        
        # 3. Si todo falla
        return (False, None, "all_failed")
    
    def _execute_fallback(self, strategy: FallbackStrategy) -> Any:
        """Ejecuta estrategia de fallback"""
        # Simulado: en producción llamaría al método
        return {"status": "fallback_executed", "method": strategy.method}
 
 
