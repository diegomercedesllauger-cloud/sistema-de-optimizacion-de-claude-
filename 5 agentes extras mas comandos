class TaskPriority(Enum):
    CRITICAL = 1
    HIGH = 2
    MEDIUM = 3
    LOW = 4
 
 
@dataclass
class Task:
    """Representa una tarea dentro de un plan"""
    id: str
    name: str
    tokens_estimated: int
    priority: TaskPriority
    dependencies: List[str] = field(default_factory=list)
    status: str = "pending"
    result: Optional[str] = None
 
 
class AgenteplanificadorInteligente:
    """
    Agente 1: Planificador Inteligente
    
    Divide tareas grandes en subtareas óptimas.
    Objetivo: Minimizar tokens totales mientras respeta prioridades.
    
    EJEMPLO:
    >> planner = AgentePlaneador()
    >> plan = planner.plan(
    ...     task="Crea 7 agentes multiagente",
    ...     token_budget=5000,
    ...     deadline_hours=48
    ... )
    >> print(plan.subtasks)  # [(Agente 1, 400 tokens), (Agente 2, 350 tokens), ...]
    """
    
    def __init__(self):
        self.task_database = {}
    
    def plan(
        self,
        task: str,
        token_budget: int,
        deadline_hours: int,
        priority: TaskPriority = TaskPriority.MEDIUM
    ) -> Dict[str, Any]:
        """
        Planifica una tarea grande dividiéndola óptimamente.
        
        Returns:
            {
                "subtasks": [(nombre, tokens), ...],
                "total_tokens": int,
                "critical_path": [(tarea1, tarea2, ...)],
                "parallelizable": [(tarea3, tarea4), ...],
                "schedule": {tarea: "hora"},
                "efficiency_score": 0-100
            }
        """
        
        # Estimar tamaño basado en palabras
        words = len(task.split())
        estimated_base = words * 15  # ~15 tokens por palabra
        
        # Heurísticas de descomposición
        if "agente" in task.lower():
            subtasks = self._decompose_agent_task(task, estimated_base)
        elif "documento" in task.lower():
            subtasks = self._decompose_document_task(task, estimated_base)
        elif "análisis" in task.lower():
            subtasks = self._decompose_analysis_task(task, estimated_base)
        else:
            subtasks = self._decompose_generic_task(task, estimated_base)
        
        # Detectar dependencias
        critical_path = self._find_critical_path(subtasks)
        parallelizable = self._find_parallelizable(subtasks)
        
        # Crear horario
        schedule = self._create_schedule(
            subtasks,
            deadline_hours,
            parallelizable
        )
        
        # Calcular eficiencia
        total_tokens = sum(st[1] for st in subtasks)
        efficiency = 100 - (total_tokens / token_budget * 100) if total_tokens < token_budget else 50
        
        return {
            "subtasks": subtasks,
            "total_tokens": total_tokens,
            "critical_path": critical_path,
            "parallelizable": parallelizable,
            "schedule": schedule,
            "efficiency_score": max(0, min(100, efficiency)),
            "within_budget": total_tokens <= token_budget,
            "recommendations": self._generate_recommendations(subtasks, token_budget)
        }
    
    def _decompose_agent_task(self, task: str, base_tokens: int) -> List[Tuple[str, int]]:
        """Descompone tarea de agentes"""
        return [
            ("1. Diseño arquitectura", base_tokens * 0.15),
            ("2. Agente 1 (Router)", base_tokens * 0.12),
            ("3. Agente 2 (Analyzer)", base_tokens * 0.12),
            ("4. Agente 3 (Validator)", base_tokens * 0.12),
            ("5. Agente 4 (Generator)", base_tokens * 0.15),
            ("6. Agente 5 (Integrador)", base_tokens * 0.12),
            ("7. Testing", base_tokens * 0.10),
        ]
    
    def _decompose_document_task(self, task: str, base_tokens: int) -> List[Tuple[str, int]]:
        """Descompone tarea de documentos"""
        return [
            ("1. Análisis preliminar", base_tokens * 0.20),
            ("2. Extracción de puntos clave", base_tokens * 0.25),
            ("3. Síntesis", base_tokens * 0.20),
            ("4. Validación", base_tokens * 0.15),
            ("5. Formato final", base_tokens * 0.20),
        ]
    
    def _decompose_analysis_task(self, task: str, base_tokens: int) -> List[Tuple[str, int]]:
        """Descompone tarea de análisis"""
        return [
            ("1. Intención", base_tokens * 0.20),
            ("2. Ambigüedades", base_tokens * 0.20),
            ("3. Validación", base_tokens * 0.20),
            ("4. Generación", base_tokens * 0.25),
            ("5. Recomendaciones", base_tokens * 0.15),
        ]
    
    def _decompose_generic_task(self, task: str, base_tokens: int) -> List[Tuple[str, int]]:
        """Descompone tarea genérica"""
        return [
            ("Fase 1", base_tokens * 0.30),
            ("Fase 2", base_tokens * 0.35),
            ("Fase 3", base_tokens * 0.35),
        ]
    
    def _find_critical_path(self, subtasks: List) -> List[str]:
        """Encuentra el camino crítico (tareas que no se pueden parallelizar)"""
        # Simplificado: primeras y últimas generalmente son críticas
        if len(subtasks) > 3:
            return [subtasks[0][0], subtasks[-2][0], subtasks[-1][0]]
        return [st[0] for st in subtasks]
    
    def _find_parallelizable(self, subtasks: List) -> List[Tuple[str, str]]:
        """Encuentra tareas que se pueden hacer simultáneamente"""
        if len(subtasks) > 4:
            return [(subtasks[1][0], subtasks[2][0]), (subtasks[3][0], subtasks[4][0])]
        return []
    
    def _create_schedule(self, subtasks: List, hours: int, parallel: List) -> Dict:
        """Crea horario de ejecución"""
        schedule = {}
        time_per_task = hours / len(subtasks)
        current_time = 0
        
        for i, (name, _) in enumerate(subtasks):
            schedule[name] = f"+{int(current_time)}h"
            if [x for x in parallel if name in x]:
                continue  # Parallelizable, no incrementar tiempo
            current_time += time_per_task
        
        return schedule
    
    def _generate_recommendations(self, subtasks: List, budget: int) -> List[str]:
        """Genera recomendaciones para optimizar el plan"""
        total = sum(st[1] for st in subtasks)
        recs = []
        
        if total > budget * 0.8:
            recs.append("⚠️ Gasto alto. Considera reducir scope.")
        
        if len(subtasks) > 7:
            recs.append("Muchas subtareas. Considera batch processing.")
        
        if total < budget * 0.3:
            recs.append("✓ Mucho margen. Puedes añadir validaciones.")
        
        return recs
 
 
