@dataclass
class LogEntry:
    """Entrada de log"""
    timestamp: datetime
    agent_name: str
    operation: str
    tokens_used: int
    status: str
    duration_ms: int
 
 
class AgenteLoggingInteligente:
    """
    Agente 5: Logging Inteligente
    
    Rastreo sin overhead de performance.
    Solo registra lo importante.
    Datos comprimidos.
    
    EJEMPLO:
    >> logger = AgenteLoggingInteligente()
    >> logger.log("Router", "classify", tokens=150, duration=23)
    >> stats = logger.get_summary()  # Análisis automático
    """
    
    def __init__(self, max_logs: int = 10000):
        self.logs: List[LogEntry] = []
        self.max_logs = max_logs
        self.summary_cache = None
        self.cache_timestamp = None
    
    def log(
        self,
        agent_name: str,
        operation: str,
        tokens_used: int,
        status: str = "success",
        duration_ms: int = 0
    ):
        """Registra operación de agente"""
        if len(self.logs) >= self.max_logs:
            # Purga logs antiguos
            self.logs = self.logs[-self.max_logs//2:]
        
        self.logs.append(
            LogEntry(
                timestamp=datetime.now(),
                agent_name=agent_name,
                operation=operation,
                tokens_used=tokens_used,
                status=status,
                duration_ms=duration_ms,
            )
        )
        
        # Invalidar caché
        self.summary_cache = None
    
    def get_summary(self, force_recompute: bool = False) -> Dict[str, Any]:
        """Obtiene resumen sin recomputar cada vez"""
        if self.summary_cache and not force_recompute:
            return self.summary_cache
        
        summary = {
            "total_logs": len(self.logs),
            "total_tokens": sum(l.tokens_used for l in self.logs),
            "average_tokens_per_operation": 0,
            "slowest_operations": [],
            "most_used_agents": {},
            "success_rate": 0.0,
        }
        
        if self.logs:
            # Tokens promedio
            summary["average_tokens_per_operation"] = (
                summary["total_tokens"] / len(self.logs)
            )
            
            # Top 3 operaciones lentas
            summary["slowest_operations"] = sorted(
                self.logs,
                key=lambda x: x.duration_ms,
                reverse=True
            )[:3]
            
            # Agentes más usados
            for log in self.logs:
                summary["most_used_agents"][log.agent_name] = (
                    summary["most_used_agents"].get(log.agent_name, 0) + 1
                )
            
            # Tasa de éxito
            successful = sum(1 for l in self.logs if l.status == "success")
            summary["success_rate"] = (successful / len(self.logs)) * 100
        
        self.summary_cache = summary
        return summary
    
    def export_analytics(self, filepath: str = "/tmp/analytics.json"):
        """Exporta analítica a archivo"""
        data = {
            "timestamp": datetime.now().isoformat(),
            "summary": self.get_summary(),
            "recent_logs": [
                {
                    "agent": l.agent_name,
                    "operation": l.operation,
                    "tokens": l.tokens_used,
                    "status": l.status,
                    "duration_ms": l.duration_ms,
                }
                for l in self.logs[-100:]  # Últimos 100
            ]
        }
        
        Path(filepath).write_text(json.dumps(data, indent=2))
        return filepath
 
 
