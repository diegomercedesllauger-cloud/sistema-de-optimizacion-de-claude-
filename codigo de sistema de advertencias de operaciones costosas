from enum import Enum
from dataclasses import dataclass
from typing import Dict, List, Optional, Tuple
from datetime import datetime
 
class CostLevel(Enum):
    """Niveles de costo de operación"""
    EXTREME = "🔴 EXTREMO"
    HIGH = "🟠 ALTO"
    MEDIUM = "🔵 MEDIO"
    LOW = "🟢 BAJO"
    MINIMAL = "⚫ MÍNIMO"
 
 
@dataclass
class OperationCost:
    """Información de costo de una operación"""
    name: str
    min_tokens: int
    max_tokens: int
    avg_tokens: int
    level: CostLevel
    description: str
    warning: str
    examples: List[str]
    recommendation: str
 
 
