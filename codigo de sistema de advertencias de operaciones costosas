    def __init__(self, current_tokens_spent: int = 0, model: str = "Haiku 4.5"):
        """
        Inicializa el sistema.
        
        Args:
            current_tokens_spent: Tokens ya gastados esta sesión
            model: Modelo que estás usando (Haiku/Sonnet/Opus)
        """
        self.current_tokens_spent = current_tokens_spent
        self.model = model
        self.limit = self.MODEL_LIMITS.get(model, 190000)
        self.tokens_remaining = self.limit - current_tokens_spent
        self.total_messages_available = max(0, self.tokens_remaining // 680)
    
    def check_operation(
        self,
        operation_key: str,
        allow_proceed: bool = False
    ) -> Tuple[bool, str]:
        """
        Verifica si una operación es segura.
        
        Returns:
            (bool, str): (es_seguro, mensaje_advertencia)
        """
        
        if operation_key not in self.OPERATION_COSTS:
            return False, f"❌ Operación '{operation_key}' no reconocida"
        
        operation = self.OPERATION_COSTS[operation_key]
        messages_needed = max(1, operation.avg_tokens // 680)
        
        # Calcular si hay suficientes tokens
        is_safe = operation.avg_tokens <= self.tokens_remaining
        
        # Construir mensaje
        message = self._build_warning_message(operation, messages_needed, is_safe)
        
        return is_safe, message
    
    def _build_warning_message(
        self,
        operation: OperationCost,
        messages_needed: int,
        is_safe: bool
    ) -> str:
        """Construye el mensaje de advertencia personalizado"""
        
        status_icon = "✅" if is_safe else "❌"
        status_text = "PUEDES PROCEDER" if is_safe else "NO RECOMENDADO"
        
        message = f"""
╔════════════════════════════════════════════════════════════╗
║  {status_icon} ADVERTENCIA DE GASTO - {operation.level.value}
╚════════════════════════════════════════════════════════════╝
 
📋 OPERACIÓN: {operation.name}
   {operation.description}
 
⚠️  {operation.warning}
 
📊 ANÁLISIS:
   • Tokens requeridos: {operation.avg_tokens:,} (aprox)
   • Rango: {operation.min_tokens:,} - {operation.max_tokens:,}
   • Mensajes que usará: ~{messages_needed}
   
💰 TU PRESUPUESTO:
   • Tokens gastados: {self.current_tokens_spent:,}
   • Tokens restantes: {self.tokens_remaining:,}
   • Mensajes disponibles: ~{self.total_messages_available}
   • Modelo: {self.model}
 
📌 RECOMENDACIÓN:
   {operation.recommendation}
 
🔴 VEREDICTO: {status_text}
   {'✓ Tienes suficientes tokens para esta operación' if is_safe else '❌ Te quedan pocos tokens. Considera alternativa más barata.'}
"""
        return message
    
    def suggest_alternatives(self, expensive_operation: str) -> str:
        """Sugiere operaciones alternativas más baratas"""
        
        operation = self.OPERATION_COSTS.get(expensive_operation)
        if not operation:
            return ""
        
        alternatives = []
        for op_key, op_info in self.OPERATION_COSTS.items():
            if op_info.level in [CostLevel.LOW, CostLevel.MINIMAL]:
                alternatives.append(f"  • {op_info.name} (~{op_info.avg_tokens} tokens)")
        
        return f"""
🔄 ALTERNATIVAS MÁS BARATAS:
{''.join(alternatives)}
 
💡 CONSEJO: Divide la tarea en partes más pequeñas.
"""
    
    def simulate_multiple_operations(
        self,
        operations: List[str]
    ) -> Dict[str, any]:
        """
        Simula ejecutar múltiples operaciones seguidas.
        
        Útil para planificar sesiones.
        """
        
        total_tokens = 0
        results = {
            "operations": [],
            "total_tokens": 0,
            "would_exceed": False,
            "final_remaining": self.tokens_remaining
        }
        
        for op_key in operations:
            if op_key not in self.OPERATION_COSTS:
                continue
            
            op = self.OPERATION_COSTS[op_key]
            total_tokens += op.avg_tokens
            
            would_exceed = (self.current_tokens_spent + total_tokens) > self.limit
            
            results["operations"].append({
                "name": op.name,
                "cost": op.avg_tokens,
                "cumulative": total_tokens,
                "safe": not would_exceed
            })
            
            if would_exceed:
                results["would_exceed"] = True
                break
        
        results["total_tokens"] = total_tokens
        results["final_remaining"] = self.tokens_remaining - total_tokens
        
        return results
    
    def get_status_report(self) -> str:
        """Genera un reporte de estado actual"""
        
        percentage = (self.current_tokens_spent / self.limit) * 100
        
        status = "🟢 BAJO" if percentage < 50 else "🟡 MEDIO" if percentage < 80 else "🔴 ALTO"
        
        return f"""
╔════════════════════════════════════════════════════════════╗
║  📊 ESTADO DE TOKENS - {status}
╚════════════════════════════════════════════════════════════╝
 
📈 CONSUMO:
   • Tokens gastados: {self.current_tokens_spent:,} / {self.limit:,}
   • Porcentaje: {percentage:.1f}%
   • Tokens restantes: {self.tokens_remaining:,}
 
💬 MENSAJES:
   • Disponibles (aprox): ~{self.total_messages_available}
   • Consumo promedio: ~680 tokens/mensaje
   • Proyección: {(self.limit - self.current_tokens_spent) // 680} mensajes más
 
🎯 RECOMENDACIÓN:
   {'✓ Usa sin preocupaciones' if percentage < 50 else '⚠️ Sé selectivo con operaciones costosas' if percentage < 80 else '🔴 Minimiza gasto. Usa solo lo esencial.'}
"""
 
 
