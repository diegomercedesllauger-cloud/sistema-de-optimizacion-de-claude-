Ingeniería en Ciberseguridad | Universidad Dominicano Americana
 
MODO DE USO:
    python check_tokens.py --operation "full_agent_pipeline" --current 45000
    python check_tokens.py --list-operations
    python check_tokens.py --simulate "simple_question" "concept_explanation" "two_agent_analysis"
"""
 
import argparse
import sys
from token_warning_system import TokenWarningSystem, CostLevel
 
 
def list_all_operations():
    """Muestra todas las operaciones disponibles"""
    
    print("\n" + "="*70)
    print("📋 OPERACIONES DISPONIBLES Y SU COSTO")
    print("="*70 + "\n")
    
    system = TokenWarningSystem()
    
    # Agrupar por nivel
    by_level = {}
    for op_key, op_info in system.OPERATION_COSTS.items():
        level = op_info.level
        if level not in by_level:
            by_level[level] = []
        by_level[level].append((op_key, op_info))
    
    # Mostrar por nivel
    level_order = [CostLevel.EXTREME, CostLevel.HIGH, CostLevel.MEDIUM, CostLevel.LOW, CostLevel.MINIMAL]
    
    for level in level_order:
        if level not in by_level:
            continue
        
        print(f"\n{level.value}")
        print("-" * 70)
        
        for op_key, op_info in by_level[level]:
            print(f"\n  {op_info.name}")
            print(f"    ID: '{op_key}'")
            print(f"    Tokens: {op_info.min_tokens:,} - {op_info.max_tokens:,} (~{op_info.avg_tokens:,} promedio)")
            print(f"    Descripción: {op_info.description}")
            print(f"    Recomendación: {op_info.recommendation}")
 
 
def check_single_operation(operation_key: str, current_tokens: int, model: str):
    """Verifica si una operación es segura"""
    
    system = TokenWarningSystem(
        current_tokens_spent=current_tokens,
        model=model
    )
    
    is_safe, message = system.check_operation(operation_key)
    
    print(message)
    
    if not is_safe:
        print(system.suggest_alternatives(operation_key))
        return False
    
    return True
 
 
def simulate_operations(operations: list, current_tokens: int, model: str):
    """Simula ejecutar múltiples operaciones"""
    
    system = TokenWarningSystem(
        current_tokens_spent=current_tokens,
        model=model
    )
    
    print(f"\n{'='*70}")
    print(f"🔮 SIMULACIÓN: {len(operations)} operaciones seguidas")
    print(f"{'='*70}\n")
    
    simulation = system.simulate_multiple_operations(operations)
    
    print(f"Tokens actuales: {current_tokens:,}")
    print(f"Modelo: {model}\n")
    
    for i, op in enumerate(simulation["operations"], 1):
        status = "✓" if op["safe"] else "❌"
        print(f"{i}. {status} {op['name']}")
        print(f"   Costo: {op['cost']:,} tokens")
        print(f"   Total acumulado: {op['cumulative']:,} tokens")
        print()
    
    if simulation["would_exceed"]:
        print(f"❌ ADVERTENCIA: Excederías el límite")
        print(f"   Podrías ejecutar solo {len(simulation['operations'])-1} de {len(operations)} operaciones")
    else:
        print(f"✅ SEGURO: Tienes suficientes tokens")
        print(f"   Te quedarían: {simulation['final_remaining']:,} tokens después")
    
    return not simulation["would_exceed"]
 
 
def main():
    parser = argparse.ArgumentParser(
        description="🚨 Sistema de Advertencia de Tokens para Claude",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
EJEMPLOS:
 
  # Ver todas las operaciones
  python check_tokens.py --list-operations
  
  # Verificar una operación específica
  python check_tokens.py --operation full_agent_pipeline --current 45000
  
  # Simular 3 operaciones seguidas
  python check_tokens.py --simulate simple_question concept_explanation two_agent_analysis --current 45000
  
  # Cambiar modelo
  python check_tokens.py --operation analyze_long_document --current 50000 --model Sonnet 4.5
  
  # Ver estado actual
  python check_tokens.py --status --current 75000
        """
    )
    
    parser.add_argument(
        "--list-operations",
        action="store_true",
        help="Muestra todas las operaciones disponibles"
    )
    
    parser.add_argument(
        "--operation",
        type=str,
        help="Verifica el costo de una operación específica"
    )
    
    parser.add_argument(
        "--simulate",
        nargs="+",
        help="Simula ejecutar múltiples operaciones seguidas"
    )
    
    parser.add_argument(
        "--current",
        type=int,
        default=0,
        help="Tokens ya gastados en esta sesión (default: 0)"
    )
    
    parser.add_argument(
        "--model",
        type=str,
        default="Haiku 4.5",
        choices=["Haiku 4.5", "Sonnet 4.5", "Opus 4.5"],
        help="Modelo que estás usando (default: Haiku 4.5)"
    )
    
    parser.add_argument(
        "--status",
        action="store_true",
        help="Muestra estado actual de tokens"
    )
    
    args = parser.parse_args()
    
    # Si no hay argumentos, mostrar ayuda
    if len(sys.argv) == 1:
        parser.print_help()
        return
    
    # Ejecutar acciones
    if args.list_operations:
        list_all_operations()
    
    elif args.operation:
        check_single_operation(args.operation, args.current, args.model)
    
    elif args.simulate:
        simulate_operations(args.simulate, args.current, args.model)
    
    elif args.status:
        system = TokenWarningSystem(
            current_tokens_spent=args.current,
            model=args.model
        )
        print(system.get_status_report())
 
 
if __name__ == "__main__":
    main()
